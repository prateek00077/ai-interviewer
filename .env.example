# --- NVIDIA NIM ---
# One key covers LLM (REST), ASR (gRPC) and TTS (gRPC).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
# cloud pins the hosted endpoints. local lets a reachable entry in
# config/services.local.yaml shadow its cloud counterpart, per service.
NIM_PROFILE=cloud
NIM_REQUEST_TIMEOUT_SECS=60

# --- App ---
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Comma-separated. The candidate interview page is a browser client.
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to boot in production while this is the default or <32 bytes.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
# Short by design: a leaked interview link must not be replayable later.
INTERVIEW_TOKEN_TTL_MINUTES=10
INVITE_TTL_HOURS=72
# Multi-use so a candidate whose browser crashes can rejoin. Each redemption
# still yields only a 10-minute interview token.
INVITE_MAX_REDEMPTIONS=3

# --- Database ---
# The app connects as an unprivileged role that owns nothing, so Postgres RLS
# actually applies to it. Run scripts/bootstrap_db.sql once to create the roles.
DATABASE_URL=postgresql+asyncpg://app_user:app_pw@localhost:5432/ai_interviewer
# Alembic only. Owns the schema; the app must never use this.
DATABASE_OWNER_URL=postgresql+asyncpg://app_owner:owner_pw@localhost:5432/ai_interviewer

# --- Redis (live session state + Celery broker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object storage (MinIO locally, R2/S3 in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_RESUMES=resumes
S3_BUCKET_RECORDINGS=recordings
S3_BUCKET_PROCTORING=proctoring
S3_BUCKET_REPORTS=reports

# --- Voice ---
CONNECT_PREWARM_TIMEOUT_SECS=45   # Magpie TTS cold start is real; gate session start on it
USE_SILERO_VAD_TURN_DETECTION=false
# End-of-turn silence. 0.2 cuts off anyone who pauses to think mid-answer.
VAD_STOP_SECS=0.8
VAD_MIN_VOLUME=0.4

# Silence before the interviewer checks in ("still with me?"), and how many
# times it does so before ending the session.
VOICE_IDLE_NUDGE_SECS=25
VOICE_MAX_IDLE_NUDGES=2
MAX_INTERVIEW_MINUTES=45

# --- Proctoring defaults (per-job policy overrides these) ---
PROCTOR_BLUR_LIMIT=3
PROCTOR_AUTO_TERMINATE=false
PROCTOR_CAMERA_ENABLED=true
PROCTOR_FRAME_INTERVAL_SECS=10

# --- Rate limiting ---
# These are the PRODUCTION numbers and are what ships. In development they are
# raised automatically (500 registrations/hour, 1000 logins) because five an
# hour makes the product untestable -- every walkthrough run needs a fresh
# tenant. Set either explicitly and your value wins in every environment,
# including a low one to exercise the 429 path.
# REGISTER_MAX_ATTEMPTS=5
# LOGIN_MAX_ATTEMPTS=10

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
EMAIL_FROM=noreply@example.com

# Where the candidate-facing app lives. Invite links are built from this and
# never from a request Host header, which an attacker controls.
APP_BASE_URL=http://localhost:3000

# --- Reports ---
REPORT_DOWNLOAD_TTL_SECS=3600
